<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.yandex.mapkit.mapview.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" >

        <Button
            android:id="@+id/btn_back"
            android:layout_width="99dp"
            android:layout_height="36dp"
            android:layout_margin="5dp"
            android:backgroundTint="@color/gray"
            android:padding="0dp"
            android:text="@string/back_button"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </com.yandex.mapkit.mapview.MapView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_zoom_in"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/plus_button"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:backgroundTint="@color/gray"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_zoom_out"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/minus_button"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:backgroundTint="@color/gray"
            android:padding="0dp" />

        <ImageButton
            android:id="@+id/btn_to_user_location"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:backgroundTint="@color/gray"
            android:padding="0dp"
            android:src="@drawable/ic_button_center"/>

    </LinearLayout>

    <!-- Крестовина перемещения для админ-мода — нижний центр -->
    <!-- По умолчанию скрыта, показывается только в adminMode -->
    <LinearLayout
        android:id="@+id/layout_admin_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Вверх (move=2: lat+) -->
        <Button
            android:id="@+id/btn_move_up"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="▲"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:backgroundTint="#AA1A6FCC"
            android:padding="0dp" />

        <!-- Влево / Вправо -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp">

            <!-- Влево (move=3: lon-) -->
            <Button
                android:id="@+id/btn_move_left"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="◀"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:backgroundTint="#AA1A6FCC"
                android:padding="0dp" />

            <!-- Пустая середина -->
            <View
                android:layout_width="56dp"
                android:layout_height="56dp" />

            <!-- Вправо (move=1: lon+) -->
            <Button
                android:id="@+id/btn_move_right"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="▶"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:backgroundTint="#AA1A6FCC"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Вниз (move=4: lat-) -->
        <Button
            android:id="@+id/btn_move_down"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="▼"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:backgroundTint="#AA1A6FCC"
            android:padding="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>