<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC2C2C2C">

    <LinearLayout
        android:id="@+id/prologueContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:alpha="0.0">

        <TextView
            android:id="@+id/tvPrologueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:gravity="center"
            android:textSize="22sp" />

        <ImageView
            android:id="@+id/ivPrologueImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="32dp"
            android:src="@drawable/ic_launcher_foreground" />
        <!-- Временно используй ic_launcher_foreground, потом заменишь на свою картинку -->

        <Button
            android:id="@+id/btnStartQuest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Начать квест →"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>